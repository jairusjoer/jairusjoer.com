---
import { Image } from "@astrojs/image/components";

let posts = await Astro.glob("../pages/projects/**/*.{md,mdx}");
posts = posts.filter((post) => !post.frontmatter.draft);
posts.sort(
  (a, b) => Date.parse(b.frontmatter.date) - Date.parse(a.frontmatter.date)
);
---

<div class="mt-24 px-6 md:px-15">
  <h3 class="font-display font-medium text-white text-18 leading-tight">
    Projects
  </h3>
</div>
<div>
  {
    posts.map(({ url, frontmatter }) => (
      <article class="mt-6">
        <a
          class="p-6 md:px-15 rounded-4xl grid md:grid-cols-2 md:gap-6 items-center"
          style={`background: ${frontmatter.color}`}
          href={url}
          target="_blank"
          rel="noopener noreferrer"
        >
          <Image
            class="h-full rounded-xl object-cover"
            src={frontmatter.image.src}
            alt={frontmatter.image?.alt ?? ''}
            format="webp"
            width={624}
            height={351}
          />
          <div class="my-6 md:my-9 text-black">
            <h4 class="font-display font-medium text-18 leading-tight">
              {frontmatter.title}
            </h4>
            <p class="mt-3 leading-relaxed">{frontmatter.description}</p>
          </div>
        </a>
      </article>
    ))
  }
</div>
