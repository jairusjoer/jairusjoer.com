---
import { getCollection } from "astro:content";
import Icon from "./icon.astro";

let sideProjects = await getCollection(
  "side-projects",
  ({ data }) => !data.draft
);
---

<div class="mt-24 px-6 md:px-15">
  <h3 class="font-display font-medium text-white text-18 leading-tight">
    Side Projects
  </h3>
</div>
<div class="mt-6 grid md:grid-cols-2 gap-6">
  {
    sideProjects.map(({ data }) => (
      <article>
        <a
          class="flex items-center gap-3 p-3 border border-zinc-800 rounded-3xl"
          href={data.url}
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="p-2.5 bg-zinc-900 rounded-xl">
            <Icon type={data.type} />
          </div>
          <div class="leading-4.5">
            <h4 class="font display font-medium text-14 text-white">
              {data.title}
            </h4>
            <p class="text-12">{data.description}</p>
          </div>
        </a>
      </article>
    ))
  }
</div>
