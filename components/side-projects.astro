---
import Icon from "./icon.astro";

let sideProjects = [
  {
    title: "Aggregata",
    description: "A blog about current software",
    url: "https://aggregata.de/",
    type: "safari",
  },
  {
    title: "jairusjoer/jairusjoer.com",
    description: "The repository behind this very site",
    url: "https://github.com/jairusjoer/jairusjoer.com",
    type: "github",
  },
];
---

<div class="mt-24 px-6 md:px-15">
  <h3 class="font-display font-medium text-white text-18 leading-tight">
    Side Projects
  </h3>
</div>
<div class="mt-6 grid md:grid-cols-2 gap-6">
  {
    sideProjects.map(({ title, description, url, type }) => (
      <article>
        <a
          class="flex items-center gap-3 p-3 border border-zinc-800 rounded-3xl"
          href={url}
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="p-2.5 bg-zinc-900 rounded-xl">
            <Icon {type} />
          </div>
          <div class="leading-4.5">
            <h4 class="font display font-medium text-14 text-white">{title}</h4>
            <p class="text-12">{description}</p>
          </div>
        </a>
      </article>
    ))
  }
</div>
