---
export interface Props {
  items?: Array<string>;
}

const { items } = Astro.props;
---

{
  items?.length && (
    <ul class="not-prosa flex flex-wrap items-center gap-1">
      {items.map((item) => (
        <li class="rounded-default bg-background-subtle px-1.5 text-sm">{item}</li>
      ))}
    </ul>
  )
}
