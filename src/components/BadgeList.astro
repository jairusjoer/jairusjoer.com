---
import Badge from './Badge.astro';

export interface Props {
  items?: Array<string>;
}

const { items } = Astro.props;
---

{
  items?.length && (
    <ul class="not-prosa flex flex-wrap items-center gap-1 text-[smaller]">
      {items.map((item) => (
        <li>
          <Badge>{item}</Badge>
        </li>
      ))}
    </ul>
  )
}
