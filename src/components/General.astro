---
import { useReader } from '../composables/useReader';
import { parse } from 'marked';

const reader = useReader();
const general = await reader.singletons.General.read({ resolveLinkedFiles: true });
---

{
  general?.about && (
    <section
      class="prose prose-sm prose-theme"
      set:html={parse(general.about)}
    />
  )
}
