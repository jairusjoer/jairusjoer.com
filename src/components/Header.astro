---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const { site } = Astro.props;

let portrait: ImageMetadata | undefined;
if (site?.general.image) {
  const { default: image } = await import(/* @vite-ignore */ site.general.image);
  portrait = image;
}
---

{
  site && (
    <header class="mb-8 flex gap-4">
      {portrait && (
        <Image
          class="size-12 rounded-lg object-cover"
          src={portrait}
          alt={site?.general.title!}
          width={96}
          height={96}
          loading="eager"
        />
      )}
      <div class="grid">
        <span class="text-foreground font-medium">{site?.general.title}</span>
        {site?.general?.description && <span>{site.general.description}</span>}
      </div>
    </header>
  )
}
