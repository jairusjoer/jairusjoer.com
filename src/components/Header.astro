---
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';

const collection = await getCollection('Pages');
---

<header class="mb-8" transition:persist>
  <nav class="text-foreground flex flex-wrap gap-2">
    <a class="borderline" href="/">{SITE_TITLE}</a>
    {
      collection.map((entry) => (
        <a class="borderline" href={`/pages/${entry.id}`}>
          {entry.data.title}
        </a>
      ))
    }
  </nav>
</header>
