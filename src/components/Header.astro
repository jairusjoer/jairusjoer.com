---
import { getCollection } from 'astro:content';

const collection = await getCollection('Pages');
const url = Astro.url.pathname;
---

<header class="mb-8">
  <nav class="text-foreground flex flex-wrap gap-2 leading-6 font-medium">
    {
      url !== '/' ? (
        <a class="bg-background size-6 rounded text-center" href="/" title="Return to homepage">
          &larr;
        </a>
      ) : (
        <span class="bg-background size-6 rounded text-center">⌘</span>
      )
    }
    <a class="borderline" href="/">CV</a>
    {
      collection.map((entry) => (
        <a class="borderline" href={`/pages/${entry.id}`}>
          {entry.data.title}
        </a>
      ))
    }
  </nav>
</header>
