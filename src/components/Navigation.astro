---
import { getCollection } from 'astro:content';

const pages = await getCollection('Pages');
const blog = await getCollection('Blog');

const isCurrentPath = (path: string) => {
  return Astro.url.pathname === path;
};

// Create navigation items with consistent structure
const items = [
  {
    title: 'About',
    href: '/',
    show: true,
  },
  {
    title: 'Blog',
    href: '/blog',
    show: blog.length > 0,
  },
  ...pages.map((entry) => ({
    title: entry.data.title,
    href: `/pages/${entry.id}`,
    show: true,
  })),
];
---

<nav class="mb-4 flex flex-wrap gap-2 font-medium">
  {
    items
      .filter((item) => item.show)
      .map(({ href, title }) => (
        <a
          class:list={{ 'text-foreground': isCurrentPath(href) }}
          {href}
        >
          {title}
        </a>
      ))
  }
</nav>
