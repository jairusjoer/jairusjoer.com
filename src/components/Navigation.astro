---
import type { Entry } from '@keystatic/core/reader';
import { getCollection } from 'astro:content';
import type keystaticConfig from '../../keystatic.config';

interface Props {
  settings: Entry<(typeof keystaticConfig)['singletons']['Settings']>;
}

const { settings } = Astro.props;
const blog = await getCollection('Blog');

const isCurrentPath = (path: string) => Astro.url.pathname === path;

const items = [
  {
    title: 'About',
    href: '/',
    hide: false,
  },
  {
    title: 'Blog',
    href: '/blog',
    hide: blog.filter((entry) => !entry.data?.draft).length === 0,
  },
  ...settings.navigation.map((item) => ({
    ...item,
    hide: false,
  })),
];
---

<nav class="mb-4 font-medium">
  <ul class="flex flex-wrap gap-2">
    {
      items
        .filter((item) => !item?.hide)
        .map((item) => (
          <li>
            <a
              class:list={{ block: true, 'text-foreground': isCurrentPath(item.href!) }}
              href={item.href}
            >
              {item.title}
            </a>
          </li>
        ))
    }
  </ul>
</nav>
