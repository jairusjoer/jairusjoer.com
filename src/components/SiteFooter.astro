---
import type { SiteConfigLink } from '../config';
import SiteNavigation from './SiteNavigation.astro';

export interface Props {
  links?: Array<SiteConfigLink>;
}

const { links } = Astro.props;
---

{
  links?.length && (
    <footer class="print-hidden mt-auto">
      <SiteNavigation links={links} />
    </footer>
  )
}
