---
import SiteNavigation from './SiteNavigation.astro';

import type { SiteConfigLink } from '../types';

export interface Props {
  links?: Array<SiteConfigLink>;
}

const { links } = Astro.props;
---

{
  links?.length && (
    <footer class="print-hidden mt-auto [view-transition-name:site-footer]">
      <SiteNavigation links={links} />
    </footer>
  )
}
