---
import { Image } from 'astro:assets';
import { site } from '../config';
import SiteNavigation from './SiteNavigation.astro';
---

<header class="flex flex-col gap-6">
  <a
    class="relative flex items-start gap-3"
    href="/"
  >
    {
      site?.portrait && (
        <Image
          class="rounded-default size-12"
          src={site.portrait}
          alt="Portrait"
          width={160}
          height={160}
          format="avif"
          loading="eager"
        />
      )
    }
    <div>
      <p class="text-foreground font-semibold">{site.title}</p>
      <p>{site.description}</p>
    </div>
  </a>

  {site?.navigation?.length && <SiteNavigation links={site.navigation} />}
</header>
