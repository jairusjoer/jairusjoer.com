---
import { Image } from 'astro:assets';
import { site } from '../config';
import SiteNavigation from './SiteNavigation.astro';
---

<header class="flex flex-col gap-6 [view-transition-name:site-header]">
  <a
    class="relative flex items-start gap-4"
    href="/"
  >
    {
      site?.image && (
        <Image
          class="rounded-default size-12"
          src={site.image}
          alt="Portrait"
          width={160}
          height={160}
          format="avif"
          loading="eager"
        />
      )
    }
    <div>
      <p class="text-foreground font-medium">{site.title}</p>
      {site?.description && <p>{site.description}</p>}
    </div>
  </a>

  {site?.navigation?.length && <SiteNavigation links={site.navigation} />}
</header>
