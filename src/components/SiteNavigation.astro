---
import type { SiteConfigLink } from '../config';
import Button from './Button.vue';

export interface Props {
  links?: Array<SiteConfigLink>;
}

const { links } = Astro.props;

const active = (path: string) => {
  if (path === '/') {
    return Astro.url.pathname === path;
  } else {
    return Astro.url.pathname.startsWith(path);
  }
};
---

{
  links?.length && (
    <nav class="print-hidden">
      <ul class="flex flex-wrap items-center gap-1.5 font-medium">
        <slot />
        {links.map((link) => (
          <li>
            <Button
              variant={active(link.href) ? 'bold' : 'ghost'}
              href={link.href}
            >
              {link.title}
            </Button>
          </li>
        ))}
      </ul>
    </nav>
  )
}
