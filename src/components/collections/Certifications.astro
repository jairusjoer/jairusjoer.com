---
import { type CollectionEntry } from 'astro:content';
import Link from '../Link.astro';
import _ from 'lodash';
import Collection from '../Collection.astro';

interface Props {
  entry: CollectionEntry<'Certifications'>;
}

const { entry } = Astro.props;
---

<Collection {entry}>
  <div slot="left">
    <span>{entry.data.issued}</span>
    {entry.data.expires && <span> – {entry.data.expires}</span>}
  </div>

  <div slot="right">
    <h3 class="text-foreground font-medium">
      <span>{entry.data.title}</span>
      <Link
        {entry}
        separator="from"
        field="organization"
      />
    </h3>
  </div>
</Collection>
