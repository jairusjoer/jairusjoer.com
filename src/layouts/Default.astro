---
import '../styles/tailwind.css';
import Meta from '../components/Meta.astro';
import Navigation from '../components/Navigation.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import type { Metadata } from '../types';
import { getCollection } from 'astro:content';

interface Props {
  metadata?: Metadata;
}

const { data: site } = (await getCollection('site'))[0];

const {
  metadata = {
    description: site.general.description,
  },
} = Astro.props;
---

<script>
  import { useExternalLinks } from '../composables/useExternalLinks';
  useExternalLinks();
</script>

<html
  lang="en"
  class="bg-background-subtle font-body antialiased print:scheme-light"
>
  <head>
    <Meta
      {site}
      {metadata}
    />
    <ClientRouter />
  </head>
  <body class="text-foreground-subtle grid min-h-screen px-4 py-16 text-sm leading-6">
    <div class="mx-auto flex w-full max-w-xl flex-col">
      <Header {site} />
      <Navigation {site} />
      <slot />
      <Footer {site} />
    </div>
  </body>
</html>
