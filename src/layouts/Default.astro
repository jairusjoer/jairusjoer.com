---
import '../styles/tailwind.css';
import Meta from '../components/Meta.astro';
import Navigation from '../components/Navigation.astro';
import { ClientRouter } from 'astro:transitions';
---

<script>
  import { useExternalLinks } from '../composables/useExternalLinks';

  useExternalLinks();
</script>

<html lang="en" class="bg-background-subtle font-body antialiased print:scheme-light">
  <head>
    <Meta />
    <ClientRouter />
  </head>
  <body class="text-foreground-subtle px-4 py-16 text-sm md:pl-16">
    <div class="max-w-xl">
      <Navigation />
      <slot />
    </div>
  </body>
</html>
