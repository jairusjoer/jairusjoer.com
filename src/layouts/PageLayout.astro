---
import '@styles/global.css';
import SiteMeta from '@components/SiteMeta.astro';
import type { Metadata as MetadataType } from '@components/SiteMeta.astro';
import { site } from '../config';
import SiteHeader from '@components/SiteHeader.astro';
import SiteFooter from '@components/SiteFooter.astro';

export interface Props {
  metadata?: Partial<MetadataType>;
}

const { metadata } = Astro.props;
---

<html
  lang={site.locale.slice(0, 2)}
  class="bg-background text-foreground-subtle text-pretty scheme-light-dark print:bg-transparent print:scheme-light"
>
  <head>
    <SiteMeta metadata={{ ...site, ...metadata }} />
    <slot name="head" />
  </head>
  <body>
    <div
      id="root"
      class="text-default font-default px-6"
    >
      <div
        class="from-background pointer-events-none fixed inset-x-0 z-10 h-24 bg-linear-to-b to-transparent print:hidden"
      >
      </div>
      <div class="max-w-default mx-auto flex min-h-dvh w-full flex-col items-start py-24 print:ml-0 print:max-w-none">
        <SiteHeader />
        <slot />
        <SiteFooter links={site.footer} />
      </div>
      <div
        class="from-background pointer-events-none fixed inset-x-0 bottom-0 z-10 h-24 bg-linear-to-t to-transparent print:hidden"
      >
      </div>
    </div>
  </body>
</html>
