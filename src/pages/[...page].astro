---
import { getCollection, render } from 'astro:content';
import { getComponents } from '@scripts/getComponents';
import PageLayout from '@layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import { formatDatetime } from '@scripts/formatDatetime';
import { isPublished } from '@scripts/isPublished';
import type { CollectionEntry } from 'astro:content';
import type { Metadata } from '@components/SiteMeta.astro';

export interface Props {
  entry: CollectionEntry<'pages'>;
}

export async function getStaticPaths() {
  let collection = await getCollection('pages');

  if (import.meta.env.PROD) {
    collection = collection.filter((entry) => isPublished(entry.data?.status));
  }

  return collection.map((entry) => ({
    params: { page: entry.id === 'index' ? undefined : entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

const { Content } = await render(entry);

const components = getComponents();

const hasExtras = entry.data.image || entry.data.description || entry.data.date;
const metadata: Partial<Metadata> = {
  id: entry.id,
  title: entry.data.title,
  description: entry.data.description,
  image: entry.data.image,
  status: entry.data.status,
};
---

<PageLayout {metadata}>
  <main class="my-24 w-full">
    <header class:list={['prosa', { 'mb-3': !hasExtras }]}>
      {
        entry.data.image && (
          <Image
            src={entry.data.image}
            alt=""
            width={864}
            height={486}
            format="avif"
          />
        )
      }
      <h1>
        {entry.data.status && <span class="text-accent">{entry.data.status}:</span>}
        {entry.data.title}
      </h1>
      {entry.data.description && <p>{entry.data.description}</p>}
      {
        entry.data.date && (
          <small class="block">
            <time>{formatDatetime(entry.data.date)}</time>
          </small>
        )
      }
      {hasExtras && <hr />}
    </header>
    <div class="prosa">
      <Content {components} />
    </div>
  </main>
</PageLayout>

<script>
  import { toggleDetails } from '@scripts/toggleDetails';
  import { externalizeLinks } from '@scripts/externalizeLinks';

  toggleDetails();
  externalizeLinks();
</script>
