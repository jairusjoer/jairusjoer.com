---
import { getCollection, render } from 'astro:content';
import { getComponents } from '@scripts/getComponents';
import PageLayout from '@layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import { formatDatetime } from '@scripts/formatDatetime';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'pages'>;
}

export async function getStaticPaths() {
  const staticPaths = [];

  let collection = await getCollection('pages');

  if (import.meta.env.PROD) {
    collection = collection.filter((entry) => !['Draft'].includes(entry.data?.status ?? ''));
  }

  for (const entry of collection) {
    staticPaths.push({
      params: { page: entry.id === 'index' ? undefined : entry.id },
      props: { entry },
    });
  }

  return staticPaths;
}

const { entry } = Astro.props;

const { Content } = await render(entry);

const components = getComponents();

const hasExtras = entry.data.image || entry.data.description || entry.data.date;
---

<PageLayout metadata={entry.data}>
  <main
    class="my-24 w-full"
    data-pagefind-body
  >
    <header
      class:list={[
        'prosa [view-transition-name:page-header]',
        hasExtras ? 'border-border mb-12 border-b pb-12' : 'mb-3',
      ]}
    >
      {
        entry.data.image && (
          <Image
            src={entry.data.image}
            alt=""
            width={864}
            height={486}
            format="avif"
          />
        )
      }
      <h1>
        {entry.data.status && <span class="text-accent">{entry.data.status}:</span>}
        <span>{entry.data.title}</span>
      </h1>
      {entry.data.description && <p>{entry.data.description}</p>}
      {
        entry.data.date && (
          <>
            <p>
              <small>
                <time>{formatDatetime(entry.data.date)}</time>
              </small>
            </p>
          </>
        )
      }
    </header>
    <div class="prosa [view-transition-name:page-article]">
      <Content {components} />
    </div>
  </main>
</PageLayout>

<script>
  import { toggleDetails } from '@scripts/toggleDetails';
  import { externalizeLinks } from '@scripts/externalizeLinks';

  toggleDetails();
  externalizeLinks();
</script>
