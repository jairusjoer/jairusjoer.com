---
import PageHeader from '@components/PageHeader.astro';
import type { Metadata } from '@components/SiteMeta.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { getComponents } from '@scripts/getComponents';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'pages'>;
}

export async function getStaticPaths() {
  const collection = await getCollection('pages');

  return collection.map((entry) => ({
    params: { page: entry.id === 'index' ? undefined : entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

const { Content } = await render(entry);

const components = getComponents();

const metadata: Metadata = {
  id: entry.id,
  title: entry.data.title,
  description: entry.data.description,
  image: entry.data.image,
  status: entry.data.status,
};
---

<PageLayout {metadata}>
  <main class="prose my-24 w-full">
    <PageHeader {entry} />
    <Content {components} />
  </main>
</PageLayout>

<script>
  import { externalizeLinks } from '@scripts/externalizeLinks';
  import { toggleDetails } from '@scripts/toggleDetails';

  toggleDetails();
  externalizeLinks();
</script>
