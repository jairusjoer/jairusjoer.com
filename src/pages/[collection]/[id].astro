---
import Default from '../../layouts/Default.astro';
import { collections } from '../../content.config';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import _ from 'lodash';
import type { CollectionEntry } from 'astro:content';
import type { CollectionKey } from 'astro:content';

export async function getStaticPaths() {
  let paths = [];

  for (const key of Object.keys(collections)) {
    const collectionKey = key as CollectionKey;
    const collection = await getCollection(collectionKey);

    const map = collection
      .filter((entry) => entry.body && entry.body.trim().length > 300)
      .map((entry) => ({
        params: { collection: _.kebabCase(collectionKey), id: entry.id },
        props: { entry },
      }));

    paths.push(...map);
  }

  return paths;
}

interface Props {
  entry: CollectionEntry<CollectionKey>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Default>
  <main>
    <div class="prose prose-sm prose-theme">
      <Content />
    </div>
  </main>
</Default>
